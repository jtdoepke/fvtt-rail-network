  "version": "0.0.0",
  "authors": [
    {
      "name": "Jaye Doepke",
      "url": "https://github.com/jtdoepke"
    }
  ],
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "esmodules": ["scripts/integration.mjs"],
  "relationships": {
    "optional": [
      { "id": "sequencer", "type": "module" },
      { "id": "calendaria", "type": "module" }
    ]
  },
  "url": "https://github.com/jtdoepke/fvtt-rail-network",
  "bugs": "https://github.com/jtdoepke/fvtt-rail-network/issues",
  "changelog": "https://github.com/jtdoepke/fvtt-rail-network/releases",
  "manifest": "https://github.com/jtdoepke/fvtt-rail-network/releases/latest/download/module.json",
